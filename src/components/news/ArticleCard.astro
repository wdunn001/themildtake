---
interface Props {
  href: string;
  title: string;
  description: string;
  datePublished: string;
  section: string;
  tags: string[];
}
const { href, title, description, datePublished, section, tags } = Astro.props;
const fmt = new Date(`${datePublished}T12:00:00Z`).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
  timeZone: "UTC",
});
---
<article class="card">
  <a class="card__link" href={href}>
    <div class="card__meta">
      <span class="card__section">{section}</span>
      <time datetime={datePublished}>{fmt}</time>
    </div>
    <h2 class="card__title">{title}</h2>
    <p class="card__desc">{description}</p>
    {tags.length > 0 && (
      <ul class="card__tags">
        {tags.slice(0, 3).map((t) => <li>{t}</li>)}
      </ul>
    )}
  </a>
</article>

<style>
  .card {
    border-bottom: 1px solid var(--border);
  }
  .card__link {
    display: block;
    padding: 1.5rem 0;
  }
  .card__link:hover .card__title { color: var(--data); }
  .card__meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-faint);
    margin-bottom: 0.5rem;
  }
  .card__section {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--data);
    font-weight: 600;
  }
  .card__title { font-size: 1.375rem; margin: 0 0 0.4rem; color: var(--fg); }
  .card__desc { margin: 0; color: var(--fg-muted); max-width: 70ch; }
  .card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0.75rem 0 0;
  }
  .card__tags li {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--fg-faint);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
  }
</style>
