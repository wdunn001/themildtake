---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Base from "./Base.astro";
import Byline from "../components/news/Byline.astro";
import Prose from "../components/Prose.astro";
import { buildArticleGraph } from "../lib/articleSchema";
import { absoluteUrl } from "../lib/site";

interface Props {
  title: string;
  description: string;
  datePublished: string;
  dateModified?: string;
  author: { name: string; url?: string };
  section: string;
  tags: string[];
  heroImage?: ImageMetadata;
  heroAlt?: string;
}

const {
  title,
  description,
  datePublished,
  dateModified,
  author,
  section,
  tags,
  heroImage,
  heroAlt,
} = Astro.props;

const site = Astro.site;
const origin = site?.origin ?? "";
const canonical = Astro.url.href;

const images: string[] = [];
if (heroImage) images.push(absoluteUrl(heroImage.src, site));

const extraGraph = buildArticleGraph({
  origin,
  canonical,
  headline: title,
  description,
  datePublished,
  dateModified,
  authorName: author.name,
  authorUrl: author.url,
  section,
  tags,
  images,
});
---
<Base
  title={`${title} - The Mild Take`}
  description={description}
  ogType="article"
  ogImage={heroImage ? heroImage.src : undefined}
  publishedTime={datePublished}
  modifiedTime={dateModified ?? datePublished}
  section={section}
  extraGraph={extraGraph}
>
  <article class="article container">
    <header class="article__head">
      <Byline
        authorName={author.name}
        authorUrl={author.url}
        datePublished={datePublished}
        dateModified={dateModified}
        section={section}
      />
      <h1 class="article__title">{title}</h1>
      <p class="article__desc">{description}</p>
      {tags.length > 0 && (
        <ul class="article__tags">
          {tags.map((t) => <li>{t}</li>)}
        </ul>
      )}
    </header>

    {heroImage && (
      <figure class="article__hero">
        <Image src={heroImage} alt={heroAlt ?? title} widths={[640, 960, 1280]} sizes="(min-width: 740px) 740px, 100vw" />
      </figure>
    )}

    <Prose>
      <slot />
    </Prose>

    <footer class="article__foot">
      <a href="/news/">&larr; All analysis</a>
    </footer>
  </article>
</Base>

<style>
  .article { max-width: 760px; padding-top: 2.5rem; padding-bottom: 4rem; }
  .article__head { margin-bottom: 2rem; }
  .article__title {
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    margin: 1rem 0 0.75rem;
  }
  .article__desc { font-size: 1.125rem; color: var(--fg-muted); max-width: 64ch; }
  .article__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 1rem 0 0;
  }
  .article__tags li {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.125rem 0.625rem;
  }
  .article__hero {
    margin: 0 0 2rem;
  }
  .article__hero :global(img) {
    width: 100%;
    height: auto;
    border-radius: 10px;
    border: 1px solid var(--border);
  }

  .article__foot {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
  .article__foot a { color: var(--fg-muted); }
  .article__foot a:hover { color: var(--data); }
</style>
