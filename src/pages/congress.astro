---
import Base from "../layouts/Base.astro";
import CongressIntegrity from "../components/ratings/CongressIntegrity";
import { SITE_NAME } from "../lib/site";
---
<Base
  title={`Is Congress representative? — ${SITE_NAME}`}
  description="Aggregating per-member integrity scores into a body-level signal: does Congress, on the whole, work for its constituents or for private interests?"
>
  <section class="container congress">
    <header class="congress__head">
      <p class="eyebrow">federal · representativeness</p>
      <h1>Is Congress representative — or captured?</h1>
      <p class="congress__lead">
        Score every member on integrity — conflicts of interest, PAC capture, stock trading,
        lobbying ties — and the aggregate says something the individual scores can't: whether
        the body <em>as a whole</em> works for its constituents or for private interests. The
        per-member data comes from the
        <a href="https://integrityindex.us/" rel="noopener" target="_blank">Integrity Index</a>;
        the aggregation and verdict are ours.
      </p>
    </header>

    <CongressIntegrity client:load />

    <p class="congress__foot">
      A low aggregate doesn't indict any single member — it's a statement about the
      <strong>composition</strong> of the body. See the
      <a href="/methodology/">methodology</a> for how integrity feeds the institutional and
      political-social categories, and <a href="/resources/">resources</a> for the data sources.
    </p>
  </section>
</Base>

<style>
  .congress { padding: 3rem 0 5rem; }
  .congress__head { margin-bottom: 2rem; }
  .congress__head h1 { font-size: clamp(1.875rem, 4vw, 2.5rem); }
  .congress__lead { color: var(--fg-muted); max-width: 70ch; }
  .congress__lead em { color: var(--fg); font-style: italic; }
  .congress__foot {
    margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border);
    color: var(--fg-muted); font-size: 0.9375rem; max-width: 70ch;
  }
  .congress__foot strong { color: var(--fg); }
</style>
