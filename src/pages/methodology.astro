---
import Base from "../layouts/Base.astro";
import Prose from "../components/Prose.astro";
import { Content } from "../../methodology.md";
import { SITE_NAME } from "../lib/site";
---
<Base
  title={`Methodology — ${SITE_NAME}`}
  description="How country risk scores are produced: a -10..+10 directional scale, explicit confidence, source discipline with a hard exclusion rule, and skew characterization."
>
  <section class="container methodology">
    <header class="methodology__head">
      <p class="eyebrow">methodology</p>
    </header>
    <Prose>
      <Content />
    </Prose>
    <footer class="methodology__foot">
      <a href="/ratings/">See the ratings &rarr;</a>
    </footer>
  </section>
</Base>

<style>
  .methodology { padding: 2.5rem 0 5rem; max-width: 820px; }
  .methodology__head { margin-bottom: 1rem; }
  .methodology__foot {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
  .methodology__foot a { color: var(--fg-muted); }
  .methodology__foot a:hover { color: var(--data); }
</style>
