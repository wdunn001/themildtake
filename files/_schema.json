{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Country Risk Assessment",
  "description": "Schema for a single country's assessment under the themildtake Country Risk Assessment Framework. Scores range -10 to +10; confidence 0 to 1; weights within a category sum to 1.0.",
  "type": "object",
  "required": ["country", "iso3", "methodology_version", "assessed_on", "subject_profile", "categories", "decisions"],
  "properties": {
    "country": { "type": "string" },
    "iso3": { "type": "string", "description": "ISO 3166-1 alpha-3 code" },
    "methodology_version": { "type": "string", "description": "Framework version used to generate these scores" },
    "assessed_on": { "type": "string", "format": "date", "description": "Date the assessment reflects (knowledge state)" },
    "subject_profile": {
      "type": "object",
      "description": "The individual the assessment is calibrated for; affects Personal Fit and weights.",
      "properties": {
        "summary": { "type": "string" },
        "profession": { "type": "string" },
        "citizenship": { "type": "string" },
        "stated_values": { "type": "array", "items": { "type": "string" } }
      }
    },
    "flags": {
      "type": "array",
      "description": "Outstanding caveats, e.g. pending source-discipline re-audit.",
      "items": { "type": "string" }
    },
    "category_weights_by_decision": {
      "type": "object",
      "description": "Weight of each category for each decision. Each decision's weights sum to 1.0.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "number" }
      }
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["score", "confidence", "sub_factors"],
        "properties": {
          "score": { "type": "number", "minimum": -10, "maximum": 10 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "skew": { "type": "string", "enum": ["positive", "negative", "symmetric", "unknown"] },
          "notes": { "type": "string" },
          "sub_factors": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["weight", "confidence"],
              "properties": {
                "score": { "type": ["number", "null"], "description": "Single-horizon score; null if split into near/long" },
                "score_near": { "type": ["number", "null"], "description": "Near-term (1-3y) score for time-sensitive factors" },
                "score_long": { "type": ["number", "null"], "description": "Long-term (5-10y) score for time-sensitive factors" },
                "weight": { "type": "number", "minimum": 0, "maximum": 1 },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "decisions": {
      "type": "object",
      "description": "Final decision-level scores. Keys: living, assets, currency.",
      "additionalProperties": {
        "type": "object",
        "required": ["score", "confidence", "horizon", "reading"],
        "properties": {
          "score": { "type": "number", "minimum": -10, "maximum": 10 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "horizon": { "type": "string" },
          "reading": { "type": "string", "description": "Threshold interpretation: clear positive / mixed / clear negative" }
        }
      }
    },
    "summary": { "type": "string", "description": "Narrative summary of the country's profile and the headline finding." }
  }
}
