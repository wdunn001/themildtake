# Copy to .env on the deploy host and adjust. These map to docker-compose.yml.

# Public origin baked into canonical URLs, JSON-LD, and the sitemap at build time.
PUBLIC_SITE_URL=https://themildtake.example

# Comma-separated hostnames the jwilder proxy routes to this container, and the
# same list as the cert SAN. EVERY hostname listed here MUST resolve in DNS to
# the Docker host (192.168.1.198) before bringing the container up — acme.sh
# issues multi-SAN certs atomically, so a single NXDOMAIN tanks the whole cert.
PROXY_THEMILDTAKE_HOSTS=themildtake.example

# Email used by Let's Encrypt for cert expiry notices.
LETSENCRYPT_EMAIL=admin@themildtake.example

# External Docker network shared with jwilder/nginx-proxy + letsencrypt-companion.
# Default matches the masszerofpv / codec setup on the same host.
NGINX_PROXY_NETWORK=nginx-proxy
